<header class="c-header full-width">
  <div class="c-header__inner c-container">
    <details class="c-header__mobile">
      <summary class="c-header__burger" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </summary>
      <nav class="c-header__drawer">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="c-header__drawer-account">My account</a>
        {%- endif -%}
      </nav>
    </details>

    <a href="{{ routes.root_url }}" class="c-header__logo">{{ shop.name }}</a>

    <nav class="c-header__nav">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="c-header__link{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="c-header__icons">
      <a href="{{ routes.search_url }}" class="c-header__icon" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      {%- if shop.customer_accounts_enabled -%}
        <shopify-account menu="{{ section.settings.customer_account_menu }}" class="c-header__icon c-header__account">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="c-header__icon c-header__cart" aria-label="Cart">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {%- if cart.item_count > 0 -%}<sup class="c-header__count">{{ cart.item_count }}</sup>{%- endif -%}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .c-header { position: sticky; top: 0; z-index: 50; background: var(--c-bg); border-bottom: 1px solid var(--c-border); }
  .c-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 72px;
    gap: 1rem;
  }
  .c-header__mobile { display: none; }
  .c-header__logo {
    grid-column: 2;
    justify-self: center;
    font-family: var(--c-serif);
    font-weight: 600;
    font-size: 1.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--c-ink);
    white-space: nowrap;
  }
  .c-header__nav {
    grid-column: 2;
    justify-self: center;
    display: flex;
    gap: 1.7rem;
  }
  /* On desktop the logo sits left, nav centre, icons right */
  @media (min-width: 901px) {
    .c-header__logo { grid-column: 1; justify-self: start; }
  }
  .c-header__link {
    font-family: var(--c-sans);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: var(--c-ink);
    position: relative;
    padding: 0.3em 0;
    white-space: nowrap;
  }
  .c-header__link::after {
    content: "";
    position: absolute;
    left: 0; bottom: 0;
    width: 0; height: 1px;
    background: var(--c-accent);
    transition: width 0.25s ease;
  }
  .c-header__link:hover::after, .c-header__link.is-active::after { width: 100%; }
  .c-header__icons { grid-column: 3; justify-self: end; display: flex; align-items: center; gap: 0.6rem; }
  .c-header__icon { color: var(--c-ink); background: none; border: 0; padding: 0; margin: 0; cursor: pointer; display: inline-flex; align-items: center; position: relative; }
  .c-header__icon svg { width: 21px; height: 21px; display: block; }
  .c-header__count {
    position: absolute; top: -7px; right: -9px;
    background: var(--c-ink); color: #fff;
    font-family: var(--c-sans); font-size: 0.6rem; line-height: 1;
    min-width: 16px; height: 16px; padding: 0 3px;
    border-radius: 999px; display: grid; place-items: center;
  }
  /* Mobile drawer */
  .c-header__burger { list-style: none; cursor: pointer; display: flex; color: var(--c-ink); }
  .c-header__burger::-webkit-details-marker { display: none; }
  .c-header__burger svg { width: 24px; height: 24px; }
  .c-header__drawer {
    position: absolute; top: calc(100% + 14px); left: 0;
    background: var(--c-bg); border: 1px solid var(--c-border); border-radius: 12px;
    padding: 8px; min-width: 210px; display: flex; flex-direction: column;
    box-shadow: 0 12px 40px rgba(0,0,0,0.1);
  }
  .c-header__drawer a { font-family: var(--c-sans); font-size: 0.95rem; text-decoration: none; color: var(--c-ink); padding: 0.7em 0.8em; border-radius: 8px; }
  .c-header__drawer a:hover { background: var(--c-soft); }
  .c-header__drawer-account {
    display: block;
    border-top: 1px solid var(--c-border);
    margin-top: 4px;
    padding: 0.9em 0.8em 0.7em;
    font-family: var(--c-sans);
    font-size: 0.95rem;
    color: var(--c-ink);
    text-decoration: none;
  }
  @media (max-width: 900px) {
    .c-header__nav { display: none; }
    .c-header__mobile { display: block; grid-column: 1; justify-self: start; position: relative; }
    .c-header__logo { font-size: 1.3rem; }
    .c-header__account { display: none; }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener("click", function (e) {
    document.querySelectorAll("details.c-header__mobile[open]").forEach(function (d) {
      if (!d.contains(e.target)) d.removeAttribute("open");
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu" },
    { "type": "link_list", "id": "customer_account_menu", "label": "Account menu", "default": "customer-account-main-menu" }
  ]
}
{% endschema %}
