<section class="c-colls full-width">
  <div class="c-container">
    <header class="c-colls__head">
      <p class="c-eyebrow">Browse</p>
      <h1 class="c-colls__title">Collections</h1>
    </header>

    <div class="c-colls__grid">
      {%- for collection in collections -%}
        <a class="c-colls__card" href="{{ collection.url }}">
          <div class="c-colls__media">
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 900 | image_tag: class: 'c-colls__img', loading: 'lazy' }}
            {%- elsif collection.products.first.featured_image -%}
              {{ collection.products.first.featured_image | image_url: width: 900 | image_tag: class: 'c-colls__img', loading: 'lazy' }}
            {%- else -%}
              <div class="c-cat__ph"><span>{{ collection.title | slice: 0 }}</span></div>
            {%- endif -%}
          </div>
          <div class="c-colls__label">
            <span>{{ collection.title }}</span>
            <span class="c-colls__count">{{ collection.products_count }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .c-colls { padding: clamp(40px, 6vw, 80px) 0 clamp(60px, 8vw, 100px); }
  .c-colls__head { margin-bottom: 2rem; }
  .c-colls__head .c-eyebrow { margin-bottom: 0.6rem; }
  .c-colls__title { font-family: var(--c-serif); font-weight: 600; font-size: clamp(2.2rem, 4.5vw, 3.4rem); }
  .c-colls__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .c-colls__card { display: block; text-decoration: none; color: var(--c-ink); }
  .c-colls__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; border-radius: 12px; background: var(--c-soft); }
  .c-colls__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.55s ease; }
  .c-colls__card:hover .c-colls__img { transform: scale(1.05); }
  .c-colls__label { display: flex; justify-content: space-between; align-items: baseline; padding: 0.9rem 0.2rem 0; font-family: var(--c-serif); font-size: 1.3rem; font-weight: 600; }
  .c-colls__count { font-family: var(--c-sans); font-size: 0.8rem; color: var(--c-muted); }
  @media (max-width: 900px) { .c-colls__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .c-colls__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections list",
  "settings": []
}
{% endschema %}
