<section
  class="c-hero full-width"
  style="--c-hero-h: {{ section.settings.height }}vh; --c-overlay: {{ section.settings.overlay | divided_by: 100.0 }};"
>
  {%- if section.settings.image != blank -%}
    <div class="c-hero__bg">
      {{ section.settings.image | image_url: width: 2400 | image_tag: class: 'c-hero__img', loading: 'eager' }}
    </div>
  {%- else -%}
    <div class="c-hero__bg">
      <img class="c-hero__img" src="{{ 'hero.jpg' | asset_url }}" alt="" loading="eager" width="2600" height="1730">
    </div>
  {%- endif -%}

  <div class="c-hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="c-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="c-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="c-hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div class="c-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a class="c-btn c-btn--light" href="{{ section.settings.button_link | default: '#' }}">
          {{- section.settings.button_label -}}
        </a>
      {%- endif -%}
      {%- if section.settings.button2_label != blank -%}
        <a class="c-btn c-btn--ghost" href="{{ section.settings.button2_link | default: '#' }}">
          {{- section.settings.button2_label -}}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .c-hero {
    position: relative;
    min-height: max(520px, calc(100svh - 72px - 46px));
    display: flex;
    align-items: center;
    overflow: hidden;
    color: #fff;
    background: linear-gradient(135deg, #14130f 0%, #262421 55%, #3a3428 100%);
  }
  .c-hero__bg { position: absolute; inset: 0; }
  .c-hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .c-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, calc(var(--c-overlay, 0.4) + 0.2)),
      rgba(0, 0, 0, var(--c-overlay, 0.35)) 70%
    );
  }
  .c-hero__inner {
    position: relative;
    z-index: 2;
    max-width: var(--c-container);
    margin-inline: auto;
    padding-block: clamp(56px, 9vw, 120px);
    padding-inline: var(--c-gutter);
    width: 100%;
  }
  .c-hero__eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--c-accent);
    margin-bottom: 1.2rem;
  }
  .c-hero__heading {
    font-family: var(--c-serif);
    font-weight: 600;
    font-size: clamp(2.6rem, 6vw, 4.75rem);
    line-height: 1.02;
    letter-spacing: -0.01em;
    max-width: 16ch;
  }
  .c-hero__sub {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 46ch;
    margin-top: 1.4rem;
  }
  .c-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 2.3rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cartello hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Autumn / Winter Collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Considered menswear, made to endure." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium tailoring, outerwear and accessories in the modern classic tradition." },
    { "type": "text", "id": "button_label", "label": "Primary button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "button2_label", "label": "Secondary button label", "default": "New arrivals" },
    { "type": "url", "id": "button2_link", "label": "Secondary button link" },
    { "type": "range", "id": "height", "label": "Height", "min": 50, "max": 95, "step": 1, "unit": "vh", "default": 80 },
    { "type": "range", "id": "overlay", "label": "Image darkening", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 40 }
  ],
  "presets": [{ "name": "Cartello hero" }]
}
{% endschema %}
