<section class="c-cart full-width">
  <div class="c-container">
    <h1 class="c-cart__title">Shopping bag</h1>

    {%- if cart.item_count == 0 -%}
      <div class="c-cart__empty">
        <p>Your bag is currently empty.</p>
        <a href="/collections/all" class="c-btn c-btn--solid">Continue shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" class="c-cart__grid">
        <div class="c-cart__items">
          {%- for item in cart.items -%}
            <div class="c-cart__row">
              <a href="{{ item.url }}" class="c-cart__media">
                {%- if item.image -%}{{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}{%- endif -%}
              </a>
              <div class="c-cart__body">
                <a href="{{ item.url }}" class="c-cart__name">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="c-cart__variant">{{ item.variant.title }}</div>
                {%- endunless -%}
                <div class="c-cart__unit">{{ item.final_price | money }}</div>
                <a href="{{ item.url_to_remove }}" class="c-cart__remove">Remove</a>
              </div>
              <input class="c-cart__qtyin" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
              <div class="c-cart__linetotal">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
          <button type="submit" class="c-cart__update">Update bag</button>
        </div>

        <aside class="c-cart__summary">
          <h2>Order summary</h2>
          <div class="c-cart__srow">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p class="c-cart__note">Shipping &amp; taxes calculated at checkout. Complimentary shipping on orders over €150.</p>
          <button type="submit" name="checkout" class="c-btn c-btn--solid c-cart__checkout">Checkout</button>
        </aside>
      </form>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .c-cart { padding: clamp(32px, 5vw, 64px) 0 clamp(60px, 8vw, 100px); }
  .c-cart__title { font-family: var(--c-serif); font-weight: 600; font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; }
  .c-cart__empty { text-align: center; padding: 4rem 0; }
  .c-cart__empty p { color: var(--c-muted); margin-bottom: 1.5rem; font-size: 1.1rem; }
  .c-cart__grid { display: grid; grid-template-columns: 1.7fr 1fr; gap: clamp(28px, 5vw, 64px); align-items: start; }
  .c-cart__items { border-top: 1px solid var(--c-border); }
  .c-cart__row {
    display: grid;
    grid-template-columns: 90px 1fr auto auto;
    gap: 1.2rem;
    align-items: center;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--c-border);
  }
  .c-cart__media { display: block; width: 100%; aspect-ratio: 3/4; border-radius: 8px; overflow: hidden; background: var(--c-soft); }
  .c-cart__media img { width: 100%; height: 100%; object-fit: cover; }
  .c-cart__name { font-family: var(--c-serif); font-size: 1.15rem; font-weight: 600; text-decoration: none; color: var(--c-ink); }
  .c-cart__variant { font-family: var(--c-sans); font-size: 0.82rem; color: var(--c-muted); margin: 0.2rem 0; }
  .c-cart__unit { font-family: var(--c-sans); font-size: 0.85rem; color: var(--c-muted); }
  .c-cart__remove { font-family: var(--c-sans); font-size: 0.78rem; color: var(--c-muted); text-decoration: underline; text-underline-offset: 2px; display: inline-block; margin-top: 0.4rem; }
  .c-cart__remove:hover { color: var(--c-ink); }
  .c-cart__qtyin { width: 58px; text-align: center; border: 1px solid var(--c-border); border-radius: 999px; padding: 0.5em; font-family: var(--c-sans); }
  .c-cart__linetotal { font-family: var(--c-sans); font-weight: 500; white-space: nowrap; }
  .c-cart__update { background: none; border: 0; font-family: var(--c-sans); font-size: 0.82rem; color: var(--c-muted); text-decoration: underline; text-underline-offset: 3px; cursor: pointer; margin-top: 1.2rem; padding: 0; }
  .c-cart__update:hover { color: var(--c-ink); }
  .c-cart__summary { border: 1px solid var(--c-border); border-radius: 14px; padding: 1.8rem; position: sticky; top: 92px; }
  .c-cart__summary h2 { font-family: var(--c-serif); font-size: 1.4rem; font-weight: 600; margin-bottom: 1.2rem; }
  .c-cart__srow { display: flex; justify-content: space-between; font-family: var(--c-sans); font-size: 1.05rem; padding-bottom: 1rem; border-bottom: 1px solid var(--c-border); }
  .c-cart__note { font-family: var(--c-sans); font-size: 0.8rem; color: var(--c-muted); line-height: 1.6; margin: 1rem 0 1.4rem; }
  .c-cart__checkout { width: 100%; }
  @media (max-width: 749px) {
    .c-cart__grid { grid-template-columns: 1fr; }
    .c-cart__row { grid-template-columns: 70px 1fr auto; }
    .c-cart__linetotal { grid-column: 2 / 4; text-align: right; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
