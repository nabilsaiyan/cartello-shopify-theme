<section class="c-contact full-width">
  <div class="c-container c-contact__inner">
    <header class="c-contact__head">
      <p class="c-eyebrow">Contact</p>
      <h1 class="c-contact__title">{{ page.title | default: 'Get in touch' }}</h1>
      {%- if page.content != blank -%}<div class="rte c-contact__intro">{{ page.content }}</div>{%- endif -%}
    </header>

    {%- form 'contact', class: 'c-contact__form' -%}
      {%- if form.posted_successfully? -%}
        <p class="c-contact__ok">Thank you — we've received your message and will be in touch shortly.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="c-contact__err">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="c-contact__row">
        <label>Name
          <input type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required>
        </label>
        <label>Email
          <input type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
        </label>
      </div>
      <label>Message
        <textarea name="contact[body]" rows="6" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
      </label>
      <button type="submit" class="c-btn c-btn--solid">Send message</button>
    {%- endform -%}
  </div>
</section>

{% stylesheet %}
  .c-contact { padding: clamp(40px, 6vw, 80px) 0 clamp(60px, 8vw, 100px); }
  .c-contact__inner { max-width: 640px; }
  .c-contact__head { margin-bottom: 2rem; }
  .c-contact__head .c-eyebrow { margin-bottom: 0.6rem; }
  .c-contact__title { font-family: var(--c-serif); font-weight: 600; font-size: clamp(2.2rem, 4.5vw, 3.2rem); }
  .c-contact__intro { color: var(--c-muted); margin-top: 0.8rem; }
  .c-contact__form { display: flex; flex-direction: column; gap: 1.1rem; }
  .c-contact__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  .c-contact__form label { display: flex; flex-direction: column; gap: 0.4rem; font-family: var(--c-sans); font-size: 0.82rem; font-weight: 500; }
  .c-contact__form input, .c-contact__form textarea {
    border: 1px solid var(--c-border); border-radius: 10px; padding: 0.8em 1em;
    font-family: var(--c-sans); font-size: 0.95rem; font-weight: 400; background: var(--c-bg); color: var(--c-ink);
  }
  .c-contact__form input:focus, .c-contact__form textarea:focus { outline: none; border-color: var(--c-ink); }
  .c-contact__form textarea { resize: vertical; }
  .c-contact__form .c-btn { align-self: flex-start; margin-top: 0.4rem; }
  .c-contact__ok { background: var(--c-soft); border-left: 3px solid var(--c-accent); padding: 1rem 1.2rem; border-radius: 8px; font-family: var(--c-sans); }
  .c-contact__err { color: #b3261e; font-family: var(--c-sans); font-size: 0.9rem; }
  @media (max-width: 520px) { .c-contact__row { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact",
  "settings": []
}
{% endschema %}
