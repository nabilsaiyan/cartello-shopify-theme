<section class="c-page full-width">
  <div class="c-container c-page__inner">
    <header class="c-page__head">
      <h1 class="c-page__title">{{ page.title }}</h1>
    </header>
    <div class="rte">{{ page.content }}</div>
  </div>
</section>

{% stylesheet %}
  .c-page { padding: clamp(40px, 6vw, 80px) 0 clamp(60px, 8vw, 100px); }
  .c-page__inner { max-width: 760px; }
  .c-page__head { margin-bottom: 2rem; }
  .c-page__title { font-family: var(--c-serif); font-weight: 600; font-size: clamp(2.2rem, 4.5vw, 3.4rem); }
{% endstylesheet %}

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
