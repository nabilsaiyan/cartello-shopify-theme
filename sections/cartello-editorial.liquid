<section class="c-editorial full-width">
  <div class="c-editorial__inner c-container {% if section.settings.reverse %}c-editorial__inner--reverse{% endif %}">
    <div class="c-editorial__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'c-editorial__img', loading: 'lazy' }}
      {%- else -%}
        <img class="c-editorial__img" src="{{ 'editorial.jpg' | asset_url }}" alt="Cartello — considered menswear" loading="lazy" width="1400" height="1750">
      {%- endif -%}
    </div>
    <div class="c-editorial__text">
      {%- if section.settings.eyebrow != blank -%}<p class="c-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="c-editorial__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.body != blank -%}<div class="c-editorial__body">{{ section.settings.body }}</div>{%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="c-btn c-btn--dark-ghost" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .c-editorial { padding: clamp(40px, 6vw, 90px) 0; background: var(--c-bg); }
  .c-editorial__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }
  .c-editorial__inner--reverse .c-editorial__media { order: 2; }
  .c-editorial__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 14px;
    background: var(--c-soft);
  }
  .c-editorial__img { width: 100%; height: 100%; object-fit: cover; }
  .c-editorial__ph {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: linear-gradient(150deg, #1c1a16, #322d22);
  }
  .c-editorial__ph span { font-family: var(--c-serif); font-size: 6rem; color: var(--c-accent); opacity: 0.6; }
  .c-editorial__text .c-eyebrow { margin-bottom: 0.9rem; }
  .c-editorial__heading {
    font-family: var(--c-serif);
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.05;
    margin-bottom: 1.1rem;
  }
  .c-editorial__body {
    font-family: var(--c-sans);
    color: var(--c-muted);
    font-size: 1.02rem;
    line-height: 1.7;
    max-width: 44ch;
    margin-bottom: 1.8rem;
  }
  @media (max-width: 749px) {
    .c-editorial__inner { grid-template-columns: 1fr; }
    .c-editorial__inner--reverse .c-editorial__media { order: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cartello editorial",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our philosophy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fewer things, better made." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Cartello is built on a simple belief: that a wardrobe should be composed of pieces worth keeping. We work with Italian mills and traditional makers to create menswear designed to outlast trends — and seasons.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Cartello editorial" }]
}
{% endschema %}
