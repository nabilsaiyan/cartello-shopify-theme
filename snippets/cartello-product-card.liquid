{% doc %}
  Renders a Cartello product card (image with hover-swap, type, title, price).

  @param {product} product - The product to render

  @example
  {% render 'cartello-product-card', product: product %}
{% enddoc %}

{% liquid
  assign img1 = product.featured_media
  assign img2 = product.media[1]
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
%}

<a class="c-card" href="{{ product.url }}">
  <div class="c-card__media{% if img2 %} c-card__media--multi{% endif %}">
    {%- if img1 -%}
      {{ img1 | image_url: width: 800 | image_tag: class: 'c-card__img c-card__img--1', loading: 'lazy' }}
    {%- else -%}
      <div class="c-card__ph"></div>
    {%- endif -%}
    {%- if img2 -%}
      {{ img2 | image_url: width: 800 | image_tag: class: 'c-card__img c-card__img--2', loading: 'lazy' }}
    {%- endif -%}
    {%- if on_sale -%}
      {%- assign pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
      <span class="c-card__badge">-{{ pct }}%</span>
    {%- endif -%}
  </div>
  <div class="c-card__body">
    {%- if product.type != blank -%}<span class="c-card__type">{{ product.type }}</span>{%- endif -%}
    <h3 class="c-card__title">{{ product.title }}</h3>
    <div class="c-card__price">
      <span class="c-card__now">{{ product.price | money }}</span>
      {%- if on_sale -%}<s class="c-card__was">{{ product.compare_at_price | money }}</s>{%- endif -%}
    </div>
  </div>
</a>

{% stylesheet %}
  .c-card { display: block; text-decoration: none; color: var(--c-ink); }
  .c-card__media {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 12px;
    background: var(--c-soft);
  }
  .c-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.5s ease, transform 0.6s ease;
  }
  .c-card__ph { position: absolute; inset: 0; background: linear-gradient(150deg, #efece6, #e0dacd); }
  .c-card__img--2 { opacity: 0; }
  .c-card__media--multi:hover .c-card__img--1 { opacity: 0; }
  .c-card__media--multi:hover .c-card__img--2 { opacity: 1; }
  .c-card:hover .c-card__img { transform: scale(1.03); }
  .c-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--c-ink);
    color: #fff;
    font-family: var(--c-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.3em 0.7em;
    border-radius: 999px;
  }
  .c-card__body { padding-top: 0.9rem; }
  .c-card__type {
    font-family: var(--c-sans);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.64rem;
    color: var(--c-muted);
  }
  .c-card__title {
    font-family: var(--c-serif);
    font-size: 1.22rem;
    font-weight: 600;
    line-height: 1.15;
    margin: 0.2rem 0 0.45rem;
  }
  .c-card__price {
    font-family: var(--c-sans);
    font-size: 0.95rem;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }
  .c-card__now { font-weight: 500; }
  .c-card__was { color: var(--c-muted); }
{% endstylesheet %}
